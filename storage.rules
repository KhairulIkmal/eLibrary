rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /covers/{fileName} {
      allow read: if true;
      allow write: if request.resource.size < 4 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }
    match /icons/{fileName} {
      allow read: if true;
      allow write: if request.resource.size < 4 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }
    match /{allPaths=**} { allow read, write: if false; }
  }
}
