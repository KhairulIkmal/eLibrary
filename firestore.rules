rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Each user can only read and write their own data
    match /users/{uid}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
    // Temporary: allow authenticated users to read old collections for migration
    match /wishlist/{docId}  { allow read: if request.auth != null; }
    match /platforms/{docId} { allow read: if request.auth != null; }
    // Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
