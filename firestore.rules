rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Username uniqueness index — any auth user can read, owner creates/deletes their slot
    match /usernames/{username} {
      allow read:   if request.auth != null;
      allow create: if request.auth != null && request.resource.data.uid == request.auth.uid;
      allow delete: if request.auth != null && resource.data.uid == request.auth.uid;
    }

    // Public profiles — any auth user can read, only owner writes
    match /profiles/{uid} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // Friend requests — sender creates, recipient reads/deletes, either side can cancel
    match /friendRequests/{toUid}/from/{fromUid} {
      allow read:   if request.auth != null && request.auth.uid == toUid;
      allow create: if request.auth != null && request.auth.uid == fromUid;
      allow delete: if request.auth != null &&
                       (request.auth.uid == toUid || request.auth.uid == fromUid);
    }

    // User's own data — full access
    match /users/{uid}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Friends can read each other's wishlist
    match /users/{uid}/wishlist/{docId} {
      allow read: if request.auth != null && (
        request.auth.uid == uid ||
        exists(/databases/$(database)/documents/users/$(uid)/friends/$(request.auth.uid))
      );
    }

    // Accept flow: acceptor writes themselves into requester's friends list
    // Only allowed if a pending request exists (prevents unsolicited adds)
    match /users/{uid}/friends/{friendUid} {
      allow create: if request.auth != null && request.auth.uid == friendUid &&
        exists(/databases/$(database)/documents/friendRequests/$(uid)/from/$(friendUid));
      allow delete: if request.auth != null && request.auth.uid == friendUid;
    }

    match /{document=**} { allow read, write: if false; }
  }
}
